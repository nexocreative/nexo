# =============================================================
# Nexo · Variables de entorno
# Copia este archivo a .env.local y rellena los valores.
# En Vercel: Project → Settings → Environment Variables.
# =============================================================

# --- NextAuth ---
# URL pública de la app. En local: http://localhost:3000
# En Vercel se puede usar la URL .vercel.app del proyecto.
NEXTAUTH_URL=http://localhost:3000
# Secreto para firmar las sesiones. Genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET=

# --- Google OAuth (proveedor de login) ---
# Crea credenciales en https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Supabase ---
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key (SECRETO, solo servidor). Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret del proyecto (Settings → API → JWT Settings). Permite que RLS
# funcione con la sesión de NextAuth.
SUPABASE_JWT_SECRET=

# --- OpenAI (IA: tickets por foto y voz) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
